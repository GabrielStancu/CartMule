<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartMule.ViewModels"
             xmlns:converters="clr-namespace:CartMule.Converters"
             x:Class="CartMule.Views.AddListPage"
             x:DataType="vm:AddListViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <ContentPage.Resources>
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
        <converters:AdaptiveFontSizeConverter x:Key="TitleFontSize" />
    </ContentPage.Resources>

    <!-- Outer Grid: layers main content + modal overlays -->
    <Grid>

        <!-- ── Main content ──────────────────────────────────────────────── -->
        <Grid RowDefinitions="Auto,*">

            <!-- ── Yellow header ─────────────────────────────────────────── -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="44,*,Auto"
                  ColumnSpacing="4"
                  Padding="{OnPlatform iOS='12,52,12,0', Default='12,24,12,0'}">

                <Button Grid.Column="0"
                        Text="←"
                        TextColor="{StaticResource TextCharcoal}"
                        BackgroundColor="Transparent"
                        FontSize="22"
                        FontFamily="OpenSansRegular"
                        FontAttributes="Bold"
                        Padding="0"
                        WidthRequest="44"
                        HeightRequest="44"
                        VerticalOptions="End"
                        Margin="0,0,0,39"
                        Command="{Binding CancelCommand}" />

                <VerticalStackLayout Grid.Column="1"
                                     VerticalOptions="End"
                                     Spacing="2"
                                     Margin="0,0,0,28">
                    <Label Text="{Binding Title}"
                           Style="{StaticResource PageTitleLabel}"
                           FontSize="{Binding Title, Converter={StaticResource TitleFontSize}}"
                           MaxLines="2"
                           LineBreakMode="WordWrap" />
                    <Label Text="{Binding Subtitle}"
                           FontSize="12"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource TextCharcoal}"
                           Opacity="0.65" />
                </VerticalStackLayout>

                <Image Grid.Column="2"
                       Source="shopping_bag.png"
                       HeightRequest="130"
                       WidthRequest="110"
                       Aspect="AspectFit"
                       VerticalOptions="End"
                       Scale="1.5" />

            </Grid>

            <!-- ── White panel with rounded top corners ──────────────────── -->
            <Border Grid.Row="1"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    Margin="0,-24,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0" />
                </Border.StrokeShape>

                <ScrollView>
                    <VerticalStackLayout Spacing="0" Padding="20,24,20,40">

                        <!-- List name -->
                        <Label Text="List Name"
                               TextColor="{StaticResource SubtleGray}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               Margin="4,0,0,6" />
                        <Border Style="{StaticResource InputBorder}"
                                Margin="0,0,0,24">
                            <Entry Text="{Binding Name}"
                                   Style="{StaticResource RoundedInputField}"
                                   Placeholder="e.g. Weekly Groceries"
                                   ReturnType="Next" />
                        </Border>

                        <!-- Shops heading -->
                        <Label Text="Shops (optional)"
                               TextColor="{StaticResource SubtleGray}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               Margin="4,0,0,10" />

                        <!-- Shop rows (auto-expanding) -->
                        <CollectionView ItemsSource="{Binding Shops}"
                                        SelectionMode="None"
                                        Margin="0,0,0,24">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShopEditItem">
                                    <Border Style="{StaticResource InputBorder}"
                                            Padding="0"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,48">
                                            <Entry Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource RoundedInputField}"
                                                   Placeholder="Add a shop…"
                                                   Margin="16,0,0,0"
                                                   ReturnType="Next"
                                                   Unfocused="OnShopUnfocused" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource PrimaryYellow}"
                                                    Stroke="Transparent"
                                                    StrokeThickness="0"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center"
                                                    IsVisible="{Binding Name, Converter={StaticResource StringNotEmpty}}">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddListViewModel}}, Path=OpenShopMenuCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="⋮"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextCharcoal}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Categories heading -->
                        <Label Text="Categories"
                               TextColor="{StaticResource SubtleGray}"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               Margin="4,0,0,10" />

                        <!-- Category rows (auto-expanding) -->
                        <CollectionView ItemsSource="{Binding Categories}"
                                        SelectionMode="None"
                                        Margin="0,0,0,24">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CategoryEditItem">
                                    <Border Style="{StaticResource InputBorder}"
                                            Padding="0"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="*,48">
                                            <Entry Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource RoundedInputField}"
                                                   Placeholder="Add a category…"
                                                   Margin="16,0,0,0"
                                                   ReturnType="Next"
                                                   Unfocused="OnCategoryUnfocused" />
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource PrimaryYellow}"
                                                    Stroke="Transparent"
                                                    StrokeThickness="0"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center"
                                                    IsVisible="{Binding Name, Converter={StaticResource StringNotEmpty}}">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddListViewModel}}, Path=OpenCategoryMenuCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="⋮"
                                                       FontSize="18"
                                                       FontAttributes="Bold"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="{StaticResource TextCharcoal}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Save -->
                        <Button Text="Save"
                                BackgroundColor="{StaticResource PrimaryYellow}"
                                TextColor="{StaticResource TextCharcoal}"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                CornerRadius="14"
                                HeightRequest="52"
                                HorizontalOptions="Fill"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,0,12" />

                        <!-- Cancel (create mode only) -->
                        <Button Text="Cancel"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                IsVisible="{Binding IsCreateMode}"
                                Command="{Binding CancelCommand}"
                                Margin="0,0,0,12" />

                        <!-- Delete list (edit mode only) -->
                        <Button Text="Delete List"
                                BackgroundColor="{StaticResource DangerRed}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="15"
                                CornerRadius="14"
                                HeightRequest="52"
                                HorizontalOptions="Fill"
                                IsVisible="{Binding IsEditMode}"
                                Command="{Binding RequestDeleteListCommand}" />

                    </VerticalStackLayout>
                </ScrollView>
            </Border>

        </Grid>

        <!-- ── Edit item modal (shared for shops and categories) ─────────── -->
        <Grid IsVisible="{Binding ShowEditModal}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="Edit"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,16" />
                    <Border Style="{StaticResource InputBorder}"
                            Margin="0,0,0,20">
                        <Entry Text="{Binding ModalEditName}"
                               Style="{StaticResource RoundedInputField}"
                               ReturnType="Done" />
                    </Border>
                    <Button Text="Save"
                            BackgroundColor="{StaticResource PrimaryYellow}"
                            TextColor="{StaticResource TextCharcoal}"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding SaveEditModalCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding DeleteEditModalItemCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelEditModalCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Delete list confirmation overlay ─────────────────────────── -->
        <Grid IsVisible="{Binding ShowDeleteListConfirm}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="Delete this list?"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8" />
                    <Label Text="All items in this list will also be permanently deleted."
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource SubtleGray}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,24" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding ConfirmDeleteListCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelDeleteListCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartMule.ViewModels"
             xmlns:models="clr-namespace:CartMule.Models"
             xmlns:converters="clr-namespace:CartMule.Converters"
             x:Class="CartMule.Views.ListDetailPage"
             x:DataType="vm:ListDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <ContentPage.Resources>
        <converters:BoolToTextDecorationConverter x:Key="BoolToTextDecoration" />
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Yellow header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="44,*,44"
              ColumnSpacing="4"
              Padding="{OnPlatform iOS='12,52,12,16', Default='12,20,12,16'}">

            <Button Grid.Column="0"
                    Text="←"
                    TextColor="{StaticResource TextCharcoal}"
                    BackgroundColor="Transparent"
                    FontSize="22"
                    FontFamily="OpenSansRegular"
                    Padding="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="Center"
                    Clicked="OnBackClicked" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="Center"
                                 Spacing="0">
                <Label Text="{Binding CreatedDisplay}"
                       FontSize="12"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextCharcoal}"
                       Opacity="0.65"
                       IsVisible="{Binding CreatedDisplay, Converter={StaticResource StringNotEmpty}}" />
                <Label Text="{Binding Title}"
                       Style="{StaticResource PageTitleLabel}"
                       FontSize="24"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    Text="✏"
                    TextColor="{StaticResource TextCharcoal}"
                    BackgroundColor="Transparent"
                    FontSize="18"
                    FontFamily="OpenSansRegular"
                    Padding="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="Center"
                    Clicked="OnRenameClicked" />
        </Grid>

        <!-- ── White panel with rounded top corners ─────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,-24,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,*">

                <!-- Search + Uncheck All row -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,100"
                      ColumnSpacing="8"
                      Margin="20,20,16,0">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource BackgroundGray}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,40" Padding="16,0">
                            <Entry Grid.Column="0"
                                   Placeholder="Filter items..."
                                   Text="{Binding SearchQuery}"
                                   BackgroundColor="Transparent"
                                   FontFamily="OpenSansRegular"
                                   FontSize="15"
                                   TextColor="{StaticResource TextCharcoal}"
                                   PlaceholderColor="{StaticResource SubtleGray}"
                                   ClearButtonVisibility="WhileEditing" />
                            <Label Grid.Column="1"
                                   Text="&#x1F50D;"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                        </Grid>
                    </Border>

                    <Button Grid.Column="1"
                            Text="Uncheck All"
                            Style="{StaticResource GhostButton}"
                            IsVisible="{Binding HasBoughtItems}"
                            Command="{Binding UncheckAllCommand}"
                            FontSize="12"
                            Padding="8,0"
                            VerticalOptions="Fill" />
                </Grid>

                <!-- Items area + FAB -->
                <Grid Grid.Row="1">

                    <!-- Empty state -->
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="8"
                                         Padding="32">
                        <Label Text="No items yet"
                               Style="{StaticResource SectionSubtitleLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="Tap + to add your first item"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource SubtleGray}"
                               FontFamily="OpenSansRegular"
                               FontSize="15" />
                    </VerticalStackLayout>

                    <!-- Grouped items list -->
                    <CollectionView ItemsSource="{Binding Groups}"
                                    IsGrouped="True"
                                    IsVisible="{Binding IsNotEmpty}"
                                    Margin="0,8,0,90"
                                    SelectionMode="None">

                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="vm:ItemGroup">
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource CategoryHeaderLabel}"
                                       Margin="20,12,16,4" />
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ShoppingItem">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Execute">
                                            <SwipeItemView WidthRequest="80"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=DeleteItemCommand}"
                                                           CommandParameter="{Binding}">
                                                <Border BackgroundColor="{StaticResource DangerRed}"
                                                        StrokeThickness="0"
                                                        WidthRequest="80">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="0,20,20,0" />
                                                    </Border.StrokeShape>
                                                    <VerticalStackLayout VerticalOptions="Center"
                                                                         HorizontalOptions="Center"
                                                                         Spacing="4">
                                                        <Label Text="&#x1F5D1;"
                                                               TextColor="White"
                                                               FontSize="20"
                                                               HorizontalOptions="Center" />
                                                        <Label Text="Delete"
                                                               TextColor="White"
                                                               FontSize="11"
                                                               FontFamily="OpenSansRegular"
                                                               HorizontalOptions="Center" />
                                                    </VerticalStackLayout>
                                                </Border>
                                            </SwipeItemView>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <VerticalStackLayout BackgroundColor="White">
                                        <Grid ColumnDefinitions="48,*"
                                              ColumnSpacing="4"
                                              Padding="20,12">

                                            <!-- Checkbox circle -->
                                            <Border Grid.Column="0"
                                                    WidthRequest="24"
                                                    HeightRequest="24"
                                                    StrokeThickness="2"
                                                    Stroke="{StaticResource SubtleGray}"
                                                    BackgroundColor="Transparent"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Start">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=ToggleBoughtCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Border.StrokeShape>
                                                    <Ellipse />
                                                </Border.StrokeShape>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsBought}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource TextCharcoal}" />
                                                        <Setter Property="Stroke" Value="{StaticResource TextCharcoal}" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="✓"
                                                       TextColor="White"
                                                       FontSize="11"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding IsBought}" />
                                            </Border>

                                            <!-- Name + Quantity -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=EditItemCommand}"
                                                        CommandParameter="{Binding}" />
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Label Text="{Binding Name}"
                                                       Style="{StaticResource ItemNameLabel}"
                                                       TextDecorations="{Binding IsBought, Converter={StaticResource BoolToTextDecoration}}"
                                                       Opacity="{Binding IsBought, Converter={StaticResource BoolToOpacity}}" />
                                                <Label Text="{Binding Quantity}"
                                                       Style="{StaticResource ListCardMetaLabel}"
                                                       IsVisible="{Binding Quantity, Converter={StaticResource StringNotEmpty}}" />
                                            </VerticalStackLayout>

                                        </Grid>
                                        <BoxView Style="{StaticResource SeparatorLine}"
                                                 Margin="20,0,0,0" />
                                    </VerticalStackLayout>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                    <!-- FAB -->
                    <Button Style="{StaticResource FABButton}"
                            Text="+"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,24,28"
                            Clicked="OnAddItemClicked" />

                </Grid>
            </Grid>
        </Border>

    </Grid>
</ContentPage>

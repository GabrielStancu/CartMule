<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartMule.ViewModels"
             xmlns:models="clr-namespace:CartMule.Models"
             xmlns:converters="clr-namespace:CartMule.Converters"
             x:Class="CartMule.Views.ListDetailPage"
             x:DataType="vm:ListDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <ContentPage.Resources>
        <converters:BoolToTextDecorationConverter x:Key="BoolToTextDecoration" />
        <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
    </ContentPage.Resources>

    <Grid>
    <Grid RowDefinitions="{OnPlatform iOS='182,*', Default='154,*'}">

        <!-- ── Yellow header (matches dashboard hero height) ─────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="44,*,Auto"
              ColumnSpacing="4"
              Padding="{OnPlatform iOS='12,52,12,0', Default='12,24,12,0'}">

            <Button Grid.Column="0"
                    Text="←"
                    TextColor="{StaticResource TextCharcoal}"
                    BackgroundColor="Transparent"
                    FontSize="22"
                    FontFamily="OpenSansRegular"
                    FontAttributes="Bold"
                    Padding="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="Start"
                    Clicked="OnBackClicked" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="End"
                                 Spacing="2"
                                 Margin="0,0,0,32">
                <Label Text="{Binding Shops}"
                       FontSize="12"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextCharcoal}"
                       Opacity="0.65"
                       IsVisible="{Binding HasShops}" />
                <Label Text="{Binding Title}"
                       Style="{StaticResource PageTitleLabel}"
                       FontSize="28"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <!-- Bag image column with edit icon overlaid at top-right -->
            <Grid Grid.Column="2">
                <Image Source="shopping_bag.png"
                       HeightRequest="130"
                       WidthRequest="110"
                       Aspect="AspectFit"
                       VerticalOptions="End"
                       Scale="1.5" />
                <ImageButton Source="edit_icon.png"
                             BackgroundColor="Transparent"
                             Padding="0"
                             WidthRequest="44"
                             HeightRequest="44"
                             VerticalOptions="Start"
                             HorizontalOptions="End"
                             Margin="0,0,8,0"
                             Clicked="OnRenameClicked" />
            </Grid>
        </Grid>

        <!-- ── White panel with rounded top corners ─────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,-24,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

                    <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Row 0: UpdatedAt + Uncheck All + yellow + button -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,52"
                      ColumnSpacing="8"
                      Padding="20,20,16,0">
                    <Label Grid.Column="0"
                           Text="{Binding UpdatedDisplay}"
                           FontSize="13"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource SubtleGray}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Uncheck All"
                            Style="{StaticResource GhostButton}"
                            IsVisible="{Binding HasBoughtItems}"
                            Command="{Binding UncheckAllCommand}"
                            FontSize="12"
                            Padding="12,0"
                            VerticalOptions="Center" />
                    <Button Grid.Column="2"
                            Text="+"
                            Style="{StaticResource FABButton}"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            FontSize="22"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Clicked="OnAddItemClicked" />
                </Grid>

                <!-- Row 1: Full-width search bar -->
                <Border Grid.Row="1"
                        BackgroundColor="{StaticResource BackgroundGray}"
                        StrokeThickness="0"
                        Margin="20,12,20,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,40" Padding="16,0">
                        <Entry Grid.Column="0"
                               Placeholder="Filter items..."
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent"
                               FontFamily="OpenSansRegular"
                               FontSize="15"
                               TextColor="{StaticResource TextCharcoal}"
                               PlaceholderColor="{StaticResource SubtleGray}"
                               ClearButtonVisibility="WhileEditing" />
                        <Image Grid.Column="1"
                               WidthRequest="20"
                               HeightRequest="20"
                               Source="search.png"/>
                    </Grid>
                </Border>

                <!-- Row 2: Items area -->
                <Grid Grid.Row="2">

                    <!-- Empty state -->
                    <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="8"
                                         Padding="32">
                        <Label Text="No items yet"
                               Style="{StaticResource SectionSubtitleLabel}"
                               HorizontalOptions="Center" />
                        <Label Text="Tap + to add your first item"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource SubtleGray}"
                               FontFamily="OpenSansRegular"
                               FontSize="15" />
                    </VerticalStackLayout>

                    <!-- Grouped items list -->
                    <CollectionView ItemsSource="{Binding Groups}"
                                    IsGrouped="True"
                                    IsVisible="{Binding IsNotEmpty}"
                                    Margin="0,8,0,0"
                                    SelectionMode="None">

                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate x:DataType="vm:ItemGroup">
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource CategoryHeaderLabel}"
                                       Margin="60,12,16,4" />
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShoppingItemViewModel">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Execute">
                                            <SwipeItemView WidthRequest="80"
                                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=RequestDeleteItemCommand}"
                                                           CommandParameter="{Binding}">
                                                <Border BackgroundColor="{StaticResource DangerRed}"
                                                        StrokeThickness="0"
                                                        WidthRequest="80">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="0,20,0,20" />
                                                    </Border.StrokeShape>
                                                    <VerticalStackLayout VerticalOptions="Center"
                                                                         HorizontalOptions="Center"
                                                                         Spacing="4">
                                                        <Label Text="&#x1F5D1;"
                                                               TextColor="White"
                                                               FontSize="20"
                                                               HorizontalOptions="Center" />
                                                        <Label Text="Delete"
                                                               TextColor="White"
                                                               FontSize="11"
                                                               FontFamily="OpenSansRegular"
                                                               HorizontalOptions="Center" />
                                                    </VerticalStackLayout>
                                                </Border>
                                            </SwipeItemView>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <VerticalStackLayout BackgroundColor="White">
                                        <VerticalStackLayout.Triggers>
                                            <DataTrigger TargetType="VerticalStackLayout"
                                                         Binding="{Binding IsDragging}"
                                                         Value="True">
                                                <Setter Property="Opacity" Value="0.4" />
                                            </DataTrigger>
                                        </VerticalStackLayout.Triggers>
                                        <VerticalStackLayout.GestureRecognizers>
                                            <DropGestureRecognizer
                                                AllowDrop="True"
                                                DropCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=ItemDroppedCommand}"
                                                DropCommandParameter="{Binding}" />
                                        </VerticalStackLayout.GestureRecognizers>

                                        <Grid ColumnDefinitions="32,48,*,44"
                                              ColumnSpacing="0"
                                              Padding="12,10,4,10">

                                            <!-- Col 0: Drag handle -->
                                            <Border Grid.Column="0"
                                                    StrokeThickness="0"
                                                    BackgroundColor="Transparent"
                                                    WidthRequest="28"
                                                    HeightRequest="36"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <DragGestureRecognizer
                                                        CanDrag="True"
                                                        DragStartingCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=ItemDragStartedCommand}"
                                                        DragStartingCommandParameter="{Binding}"
                                                        DropCompletedCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=ItemDragCompletedCommand}"
                                                        DropCompletedCommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Label Text="&#x2630;"
                                                       TextColor="{StaticResource SubtleGray}"
                                                       FontSize="15"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>

                                            <!-- Col 1: Checkbox circle -->
                                            <Border Grid.Column="1"
                                                    WidthRequest="24"
                                                    HeightRequest="24"
                                                    StrokeThickness="2"
                                                    Stroke="{StaticResource SubtleGray}"
                                                    BackgroundColor="Transparent"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=ToggleBoughtCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Border.StrokeShape>
                                                    <Ellipse />
                                                </Border.StrokeShape>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsBought}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource TextCharcoal}" />
                                                        <Setter Property="Stroke" Value="{StaticResource TextCharcoal}" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="✓"
                                                       TextColor="White"
                                                       FontSize="11"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding IsBought}" />
                                            </Border>

                                            <!-- Col 2: Name + Quantity (tap = edit) -->
                                            <VerticalStackLayout Grid.Column="2"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2"
                                                                 Padding="8,0">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=EditItemCommand}"
                                                        CommandParameter="{Binding}" />
                                                </VerticalStackLayout.GestureRecognizers>
                                                <Label Text="{Binding Name}"
                                                       Style="{StaticResource ItemNameLabel}"
                                                       TextDecorations="{Binding IsBought, Converter={StaticResource BoolToTextDecoration}}"
                                                       Opacity="{Binding IsBought, Converter={StaticResource BoolToOpacity}}" />
                                                <Label Text="{Binding Quantity}"
                                                       Style="{StaticResource ListCardMetaLabel}"
                                                       IsVisible="{Binding Quantity, Converter={StaticResource StringNotEmpty}}" />
                                            </VerticalStackLayout>

                                            <!-- Col 3: Settings icon → item options modal -->
                                            <Border Grid.Column="3"
                                                    BackgroundColor="Transparent"
                                                    StrokeThickness="0"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    VerticalOptions="Center"
                                                    HorizontalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListDetailViewModel}}, Path=RequestItemOptionsCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Border.GestureRecognizers>
                                                <Image Source="settings.png"
                                                       WidthRequest="22"
                                                       HeightRequest="22"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>

                                        </Grid>

                                        <BoxView Style="{StaticResource SeparatorLine}"
                                                 Margin="12,0,0,0" />
                                    </VerticalStackLayout>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </Grid>

                <!-- Row 3: Delete List button (always visible — list always exists here) -->
                <Button Grid.Row="3"
                        Text="Delete List"
                        BackgroundColor="{StaticResource DangerRed}"
                        TextColor="White"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        CornerRadius="0"
                        HeightRequest="52"
                        HorizontalOptions="Fill"
                        Command="{Binding RequestDeleteListCommand}"
                        Margin="0,8,0,0" />

            </Grid>
        </Border>

    </Grid>

        <!-- ── Item options modal ─────────────────────────────────────── -->
        <Grid IsVisible="{Binding ShowItemOptions}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="{Binding ItemOptionsName}"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,20" />
                    <Button Text="Edit"
                            BackgroundColor="{StaticResource PrimaryYellow}"
                            TextColor="{StaticResource TextCharcoal}"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding EditSelectedItemCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding RequestDeleteFromOptionsCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelItemOptionsCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Delete item confirmation overlay ─────────────────────── -->
        <Grid IsVisible="{Binding ShowDeleteItemConfirm}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="Delete item?"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8" />
                    <Label Text="This item will be permanently removed from the list."
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource SubtleGray}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,24" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding ConfirmDeleteItemCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelDeleteItemCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ── Delete list confirmation overlay ─────────────────────── -->
        <Grid IsVisible="{Binding ShowDeleteListConfirm}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="Delete this list?"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8" />
                    <Label Text="All items in this list will also be permanently deleted."
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource SubtleGray}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,24" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding ConfirmDeleteListCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelDeleteListCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

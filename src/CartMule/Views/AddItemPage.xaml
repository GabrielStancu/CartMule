<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartMule.ViewModels"
             xmlns:converters="clr-namespace:CartMule.Converters"
             x:Class="CartMule.Views.AddItemPage"
             x:DataType="vm:AddItemViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <ContentPage.Resources>
        <converters:AdaptiveFontSizeConverter x:Key="TitleFontSize" />
    </ContentPage.Resources>

    <Grid RowDefinitions="{OnPlatform iOS='182,*', Default='154,*'}">

        <!-- ── Yellow header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="44,*,Auto"
              ColumnSpacing="4"
              Padding="{OnPlatform iOS='12,52,12,0', Default='12,24,12,0'}">

            <Button Grid.Column="0"
                    Text="←"
                    TextColor="{StaticResource TextCharcoal}"
                    BackgroundColor="Transparent"
                    FontSize="22"
                    FontFamily="OpenSansRegular"
                    FontAttributes="Bold"
                    Padding="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="End"
                    Margin="0,0,0,39"
                    Command="{Binding CancelCommand}" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="End"
                                 Spacing="2"
                                 Margin="0,0,0,28">
                <Label Text="{Binding Title}"
                       Style="{StaticResource PageTitleLabel}"
                       FontSize="{Binding Title, Converter={StaticResource TitleFontSize}}"
                       MaxLines="2"
                       LineBreakMode="WordWrap" />
                <Label Text="{Binding Subtitle}"
                       FontSize="12"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextCharcoal}"
                       Opacity="0.65" />
            </VerticalStackLayout>

            <Image Grid.Column="2"
                   Source="shopping_bag.png"
                   HeightRequest="130"
                   WidthRequest="110"
                   Aspect="AspectFit"
                   VerticalOptions="End"
                   Scale="1.5" />

        </Grid>

        <!-- ── White panel with rounded top corners ──────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,-24,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

        <!-- ── Form area ─────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="20,24,20,40">

                <!-- Item name -->
                <Label Text="Item Name"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,20">
                    <Entry Text="{Binding Name}"
                           Style="{StaticResource RoundedInputField}"
                           Placeholder="e.g. Whole milk"
                           ReturnType="Next" />
                </Border>

                <!-- Quantity -->
                <Label Text="Quantity (optional)"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,20">
                    <Entry Text="{Binding Quantity}"
                           Style="{StaticResource RoundedInputField}"
                           Placeholder="e.g. 2 litres"
                           ReturnType="Done" />
                </Border>

                <!-- Category -->
                <Label Text="Category"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,32">
                    <Picker ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            Style="{StaticResource RoundedPicker}"
                            ItemDisplayBinding="{Binding Name}" />
                </Border>

                <!-- Save button -->
                <Button Text="Save"
                        BackgroundColor="{StaticResource PrimaryYellow}"
                        TextColor="{StaticResource TextCharcoal}"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="52"
                        HorizontalOptions="Fill"
                        Command="{Binding SaveCommand}"
                        Margin="0,0,0,12" />

                <!-- Cancel -->
                <Button Text="Cancel"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Fill"
                        Command="{Binding CancelCommand}" />

            </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>

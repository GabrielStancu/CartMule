<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartMule.ViewModels"
             x:Class="CartMule.Views.ListsDashboardPage"
             x:DataType="vm:ListsDashboardViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource BackgroundGray}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Yellow header ─────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource PrimaryYellow}"
                Padding="{OnPlatform iOS='20,52,20,20', Default='20,20,20,20'}"
                StrokeThickness="0">
            <Label Text="CartMule"
                   Style="{StaticResource PageTitleLabel}" />
        </Border>

        <!-- ── Content area ──────────────────────────────────────────── -->
        <Grid Grid.Row="1">

            <!-- Empty state -->
            <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="32">
                <Label Text="No lists yet"
                       Style="{StaticResource SectionSubtitleLabel}"
                       HorizontalOptions="Center" />
                <Label Text="Tap + to get started"
                       HorizontalOptions="Center"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="15" />
            </VerticalStackLayout>

            <!-- List cards -->
            <CollectionView ItemsSource="{Binding Lists}"
                            IsVisible="{Binding IsNotEmpty}"
                            Margin="0,8,0,90"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ListSummaryItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Execute">
                                    <SwipeItemView WidthRequest="80"
                                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListsDashboardViewModel}}, Path=DeleteListCommand}"
                                                   CommandParameter="{Binding}">
                                        <Border BackgroundColor="{StaticResource DangerRed}"
                                                StrokeThickness="0"
                                                WidthRequest="80">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="0,20,20,0" />
                                            </Border.StrokeShape>
                                            <VerticalStackLayout VerticalOptions="Center"
                                                                 HorizontalOptions="Center"
                                                                 Spacing="4">
                                                <Label Text="&#x1F5D1;"
                                                       TextColor="White"
                                                       FontSize="20"
                                                       HorizontalOptions="Center" />
                                                <Label Text="Delete"
                                                       TextColor="White"
                                                       FontSize="11"
                                                       FontFamily="OpenSansRegular"
                                                       HorizontalOptions="Center" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </SwipeItemView>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Border Style="{StaticResource ListCardBorder}"
                                    Margin="16,6">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListsDashboardViewModel}}, Path=OpenListCommand}"
                                        CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      Padding="4,0">

                                    <!-- List name -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding List.Name}"
                                           Style="{StaticResource ListCardTitleLabel}" />

                                    <!-- Item count badge -->
                                    <Border Grid.Row="0" Grid.Column="1"
                                            Style="{StaticResource CountBadgeBorder}"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding ItemCount}"
                                               Style="{StaticResource CountBadgeLabel}" />
                                    </Border>

                                    <!-- Meta row -->
                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding UpdatedDisplay}"
                                           Style="{StaticResource ListCardMetaLabel}" />
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding ItemCount, StringFormat='{0} items'}"
                                           Style="{StaticResource ListCardMetaLabel}" />

                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- FAB -->
            <Button Style="{StaticResource FABButton}"
                    Text="+"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,24,28"
                    Clicked="OnAddListClicked" />

        </Grid>
    </Grid>
</ContentPage>

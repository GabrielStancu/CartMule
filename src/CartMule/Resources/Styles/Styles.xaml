<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ====================================================
         BASE MAUI CONTROL STYLES (CartMule theme overrides)
         ==================================================== -->

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PrimaryYellow}" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource LightGray}" />
        <Setter Property="StrokeShape" Value="Rectangle" />
        <Setter Property="StrokeThickness" Value="1" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="MinimumWidthRequest" Value="48" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextCharcoal}" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryYellow}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="TitleColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="ScrollView">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="RefreshView">
        <Setter Property="RefreshColor" Value="{StaticResource PrimaryYellow}" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="OnColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="ThumbColor" Value="{StaticResource Surface}" />
    </Style>

    <!-- ====================================================
         CARTMULE NAMED STYLES
         ==================================================== -->

    <!-- Page title — large bold heading -->
    <Style x:Key="PageTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="CharacterSpacing" Value="-0.5" />
    </Style>

    <!-- Section subtitle -->
    <Style x:Key="SectionSubtitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource SubtleGray}" />
    </Style>

    <!-- Item name label (active, not bought) -->
    <Style x:Key="ItemNameLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
    </Style>

    <!-- Item name label (bought — strikethrough + dimmed) -->
    <Style x:Key="BoughtItemNameLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="TextDecorations" Value="Strikethrough" />
    </Style>

    <!-- Category group header -->
    <Style x:Key="CategoryHeaderLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="CharacterSpacing" Value="1" />
    </Style>

    <!-- List card — white rounded card on gray background -->
    <Style x:Key="ListCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Padding" Value="20,18" />
        <Setter Property="Margin" Value="16,6" />
    </Style>

    <!-- List card title -->
    <Style x:Key="ListCardTitleLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
    </Style>

    <!-- List card meta (item count, date) -->
    <Style x:Key="ListCardMetaLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource SubtleGray}" />
    </Style>

    <!-- Floating Action Button (FAB) -->
    <Style x:Key="FABButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="CornerRadius" Value="28" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="WidthRequest" Value="56" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource TextCharcoal}" Offset="0,4" Opacity="0.15" Radius="8" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Input field (rounded, white) -->
    <Style x:Key="RoundedInputField" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <!-- Rounded Picker -->
    <Style x:Key="RoundedPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="TitleColor" Value="{StaticResource SubtleGray}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <!-- Input wrapper border (surrounds Entry/Picker) -->
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Stroke" Value="{StaticResource LightGray}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <!-- Danger/delete button -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource DangerRed}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Ghost / secondary button -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="BorderColor" Value="{StaticResource LightGray}" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <!-- Separator line -->
    <Style x:Key="SeparatorLine" TargetType="BoxView">
        <Setter Property="BackgroundColor" Value="{StaticResource LightGray}" />
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <!-- Yellow accent badge / count pill -->
    <Style x:Key="CountBadgeBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryYellow}" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style x:Key="CountBadgeLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextCharcoal}" />
    </Style>

</ResourceDictionary>

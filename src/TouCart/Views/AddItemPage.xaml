<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TouCart.ViewModels"
             xmlns:converters="clr-namespace:TouCart.Converters"
             xmlns:models="clr-namespace:TouCart.Models"
             x:Class="TouCart.Views.AddItemPage"
             x:DataType="vm:AddItemViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <ContentPage.Resources>
        <converters:AdaptiveFontSizeConverter x:Key="TitleFontSize" />
    </ContentPage.Resources>

    <Grid>
    <Grid RowDefinitions="{OnPlatform iOS='182,*', Default='154,*'}">

        <!-- ── Yellow header ─────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="44,*,Auto"
              ColumnSpacing="4"
              Padding="{OnPlatform iOS='12,52,12,0', Default='12,24,12,0'}">

            <Button Grid.Column="0"
                    Text="←"
                    TextColor="{StaticResource TextCharcoal}"
                    BackgroundColor="Transparent"
                    FontSize="22"
                    FontFamily="OpenSansRegular"
                    FontAttributes="Bold"
                    Padding="0"
                    WidthRequest="44"
                    HeightRequest="44"
                    VerticalOptions="End"
                    Margin="0,0,0,30"
                    Command="{Binding CancelCommand}" />

            <VerticalStackLayout Grid.Column="1"
                                 VerticalOptions="End"
                                 Spacing="2"
                                 Margin="0,0,0,28">
                <Label Text="{Binding Title}"
                       Style="{StaticResource PageTitleLabel}"
                       FontSize="{Binding Title, Converter={StaticResource TitleFontSize}}"
                       MaxLines="2"
                       LineBreakMode="WordWrap" />
                <Label Text="{Binding Subtitle}"
                       FontSize="12"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextCharcoal}"
                       Opacity="0.65" />
            </VerticalStackLayout>

            <Image Grid.Column="2"
                   Source="shopping_bag.png"
                   HeightRequest="130"
                   WidthRequest="110"
                   Aspect="AspectFit"
                   VerticalOptions="End"
                   Scale="1.5" />

        </Grid>

        <!-- ── White panel with rounded top corners ──────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,-24,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

        <!-- ── Form area ─────────────────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0" Padding="20,24,20,40">

                <!-- Item name -->
                <Label Text="{Binding Loc.ItemNameLabel}"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,20">
                    <Entry Text="{Binding Name}"
                           Style="{StaticResource RoundedInputField}"
                           Placeholder="{Binding Loc.ItemNamePlaceholder}"
                           ReturnType="Next" />
                </Border>

                <!-- Quantity -->
                <Label Text="{Binding Loc.QuantityLabel}"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,20">
                    <Entry Text="{Binding Quantity}"
                           Style="{StaticResource RoundedInputField}"
                           Placeholder="{Binding Loc.QuantityPlaceholder}"
                           ReturnType="Done" />
                </Border>

                <!-- Category -->
                <Label Text="{Binding Loc.CategoryLabel}"
                       TextColor="{StaticResource SubtleGray}"
                       FontFamily="OpenSansRegular"
                       FontSize="13"
                       Margin="4,0,0,6" />
                <Border Style="{StaticResource InputBorder}"
                        Margin="0,0,0,32">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenCategoryPickerCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" HeightRequest="52">
                        <Label Grid.Column="0"
                               Text="{Binding SelectedCategory.Name}"
                               FontFamily="OpenSansRegular"
                               FontSize="16"
                               TextColor="{StaticResource TextCharcoal}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#x25BE;"
                               FontSize="14"
                               TextColor="{StaticResource SubtleGray}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Save button -->
                <Button Text="{Binding Loc.Save}"
                        BackgroundColor="{StaticResource PrimaryYellow}"
                        TextColor="{StaticResource TextCharcoal}"
                        FontFamily="OpenSansSemibold"
                        FontSize="16"
                        CornerRadius="14"
                        HeightRequest="52"
                        HorizontalOptions="Fill"
                        Command="{Binding SaveCommand}"
                        Margin="0,0,0,12" />

                <!-- Cancel -->
                <Button Text="{Binding Loc.Cancel}"
                        Style="{StaticResource GhostButton}"
                        HorizontalOptions="Fill"
                        Command="{Binding CancelCommand}" />

            </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>

        <!-- ── Category picker modal ─────────────────────────────────── -->
        <Grid IsVisible="{Binding ShowCategoryPicker}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="{Binding Loc.CategoryLabel}"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,20" />
                    <VerticalStackLayout Spacing="10"
                                         BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Category">
                                <Button Text="{Binding Name}"
                                        BackgroundColor="{StaticResource PrimaryYellow}"
                                        TextColor="{StaticResource TextCharcoal}"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="15"
                                        CornerRadius="12"
                                        HeightRequest="48"
                                        HorizontalOptions="Fill"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddItemViewModel}}, Path=SelectCategoryCommand}"
                                        CommandParameter="{Binding Id}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Button Text="{Binding Loc.Cancel}"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Margin="0,10,0,0"
                            Command="{Binding CloseCategoryPickerCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

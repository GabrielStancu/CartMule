<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TouCart.ViewModels"
             x:Class="TouCart.Views.ListsDashboardPage"
             x:DataType="vm:ListsDashboardViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PrimaryYellow}">

    <Grid>
    <Grid RowDefinitions="Auto,*">

        <!-- ── Hero header ───────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="{OnPlatform iOS='24,52,16,0', Default='24,24,16,0'}">

            <VerticalStackLayout Grid.Column="0"
                                 VerticalOptions="End"
                                 Spacing="2"
                                 Padding="0,0,0,28">
                <Label Text="Hello!"
                       FontSize="34"
                       FontAttributes="Bold"
                       FontFamily="OpenSansSemibold"
                       TextColor="{StaticResource TextCharcoal}" />
                <Label Text="What do you need today?"
                       FontSize="14"
                       FontFamily="OpenSansRegular"
                       TextColor="{StaticResource TextCharcoal}"
                       Opacity="0.7" />
            </VerticalStackLayout>

            <Image Grid.Column="1"
                   Source="shopping_bag.png"
                   HeightRequest="130"
                   WidthRequest="110"
                   Aspect="AspectFit"
                   VerticalOptions="End"
                   Scale="1.5"/>
        </Grid>

        <!-- ── White panel with rounded top corners ─────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Margin="0,-24,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0" />
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Heading + add button -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,52"
                      Margin="20,24,16,0">
                    <Label Grid.Column="0"
                           Text="Shopping Lists"
                           FontSize="20"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="+"
                            Style="{StaticResource FABButton}"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            FontSize="22"
                            Clicked="OnAddListClicked" />
                </Grid>

                <!-- Search bar -->
                <Border Grid.Row="1"
                        BackgroundColor="{StaticResource BackgroundGray}"
                        StrokeThickness="0"
                        Margin="20,12,20,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="*,40" Padding="16,0">
                        <Entry Grid.Column="0"
                               Placeholder="Search lists..."
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent"
                               FontFamily="OpenSansRegular"
                               FontSize="15"
                               TextColor="{StaticResource TextCharcoal}"
                               PlaceholderColor="{StaticResource SubtleGray}"
                               ClearButtonVisibility="WhileEditing" />
                        <Image Grid.Column="1"
                               WidthRequest="20"
                               HeightRequest="20"
                               Source="search.png"/>
                    </Grid>
                </Border>

                <!-- List items -->
                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding FilteredLists}"
                                Margin="0,12,0,0"
                                SelectionMode="None">

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="8"
                                             Padding="32,48">
                            <Label Text="No lists yet"
                                   Style="{StaticResource SectionSubtitleLabel}"
                                   HorizontalOptions="Center" />
                            <Label Text="Tap + above to get started"
                                   HorizontalOptions="Center"
                                   TextColor="{StaticResource SubtleGray}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="15" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ListSummaryItem">
                            <SwipeView>
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItemView WidthRequest="80"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListsDashboardViewModel}}, Path=RequestDeleteListCommand}"
                                                       CommandParameter="{Binding}">
                                            <Border BackgroundColor="{StaticResource DangerRed}"
                                                    StrokeThickness="0"
                                                    WidthRequest="80">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="0,20,20,0" />
                                                </Border.StrokeShape>
                                                <VerticalStackLayout VerticalOptions="Center"
                                                                     HorizontalOptions="Center"
                                                                     Spacing="4">
                                                    <Label Text="&#x1F5D1;"
                                                           TextColor="White"
                                                           FontSize="20"
                                                           HorizontalOptions="Center" />
                                                    <Label Text="Delete"
                                                           TextColor="White"
                                                           FontSize="11"
                                                           FontFamily="OpenSansRegular"
                                                           HorizontalOptions="Center" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <VerticalStackLayout BackgroundColor="White">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ListsDashboardViewModel}}, Path=OpenListCommand}"
                                            CommandParameter="{Binding}" />
                                    </VerticalStackLayout.GestureRecognizers>

                                    <Grid ColumnDefinitions="*,52" Padding="20,14">
                                        <VerticalStackLayout Grid.Column="0"
                                                            VerticalOptions="Center"
                                                            Spacing="3">
                                            <Label Text="{Binding List.Name}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{StaticResource TextCharcoal}" />
                                            <Label Text="{Binding CreatedDisplay}"
                                                   Style="{StaticResource ListCardMetaLabel}" />
                                            <Label Text="{Binding ItemCount, StringFormat='{0} items'}"
                                                   Style="{StaticResource ListCardMetaLabel}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{StaticResource CalmGreen}"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                StrokeThickness="0"
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center">
                                            <Border.StrokeShape>
                                                <Ellipse />
                                            </Border.StrokeShape>
                                            <Label Text="&#x2192;"
                                                   TextColor="White"
                                                   FontSize="18"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Start"
                                                   FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>

                                    <BoxView Style="{StaticResource SeparatorLine}"
                                             Margin="20,0,0,0" />
                                </VerticalStackLayout>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Grid>
        </Border>

    </Grid>

        <!-- ── Delete list confirmation overlay ──────────────────── -->
        <Grid IsVisible="{Binding ShowDeleteListConfirm}"
              BackgroundColor="#80000000">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    WidthRequest="300">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0" Padding="24">
                    <Label Text="Delete this list?"
                           FontSize="18"
                           FontAttributes="Bold"
                           FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource TextCharcoal}"
                           HorizontalOptions="Center"
                           Margin="0,0,0,8" />
                    <Label Text="All items in this list will also be permanently deleted."
                           FontSize="14"
                           FontFamily="OpenSansRegular"
                           TextColor="{StaticResource SubtleGray}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="0,0,0,24" />
                    <Button Text="Delete"
                            BackgroundColor="{StaticResource DangerRed}"
                            TextColor="White"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            CornerRadius="12"
                            HeightRequest="48"
                            HorizontalOptions="Fill"
                            Command="{Binding ConfirmDeleteListCommand}"
                            Margin="0,0,0,10" />
                    <Button Text="Cancel"
                            Style="{StaticResource GhostButton}"
                            HorizontalOptions="Fill"
                            Command="{Binding CancelDeleteListCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- TouCart Brand Palette -->
    <Color x:Key="PrimaryYellow">#FFD200</Color>
    <Color x:Key="SurfaceWhite">#FFFFFF</Color>
    <Color x:Key="TextCharcoal">#1A1A1A</Color>
    <Color x:Key="SubtleGray">#757575</Color>
    <Color x:Key="LightGray">#E8E8E8</Color>
    <Color x:Key="BackgroundGray">#F7F7F7</Color>
    <Color x:Key="DangerRed">#FF3B30</Color>
    <Color x:Key="SuccessGreen">#34C759</Color>
    <Color x:Key="CalmGreen">#3A533C</Color>

    <!-- Semantic aliases (used in Styles.xaml) -->
    <Color x:Key="Primary">#FFD200</Color>
    <Color x:Key="OnPrimary">#1A1A1A</Color>
    <Color x:Key="Background">#F7F7F7</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="OnSurface">#1A1A1A</Color>
    <Color x:Key="OnBackground">#1A1A1A</Color>

    <!-- Legacy aliases for MAUI default styles that reference these -->
    <Color x:Key="PrimaryDark">#E6BD00</Color>
    <Color x:Key="PrimaryDarkText">#1A1A1A</Color>
    <Color x:Key="Secondary">#FFF3B0</Color>
    <Color x:Key="SecondaryDarkText">#1A1A1A</Color>
    <Color x:Key="Tertiary">#FFD200</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#1A1A1A</Color>
    <Color x:Key="Gray100">#F5F5F5</Color>
    <Color x:Key="Gray200">#E8E8E8</Color>
    <Color x:Key="Gray300">#BDBDBD</Color>
    <Color x:Key="Gray400">#9E9E9E</Color>
    <Color x:Key="Gray500">#757575</Color>
    <Color x:Key="Gray600">#4A4A4A</Color>
    <Color x:Key="Gray900">#1A1A1A</Color>
    <Color x:Key="Gray950">#0D0D0D</Color>
    <Color x:Key="Magenta">#FFD200</Color>
    <Color x:Key="MidnightBlue">#1A1A1A</Color>
    <Color x:Key="OffBlack">#1A1A1A</Color>

</ResourceDictionary>